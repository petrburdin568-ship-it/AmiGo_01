{
  "name": "amigo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "android:add": "cap add android",
    "android:sync": "cap sync android",
    "android:open": "cap open android",
    "android:apk:debug": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1 -BuildType Debug",
    "android:apk:debug:existing": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1 -BuildType Debug -SkipWebBuild",
    "android:apk:debug:assets": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1 -BuildType Debug -SkipWebBuild -SkipSync",
    "android:apk:release": "powershell.exe -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1 -BuildType Release"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/push-notifications": "^8.0.3",
    "@supabase/supabase-js": "^2.49.8",
    "next": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.5.4"
  }
}
